{
  "name": "ManitoConversation",
  "type": "object",
  "properties": {
    "sessionId": {
      "type": "string",
      "title": "Session ID"
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "default": [],
      "title": "History"
    }
  },
  "required": [
    "sessionId"
  ],
  "rls": {
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}