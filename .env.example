# Environment Variables Template
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ============================================
# Base44 (Required for backend features)
# ============================================
VITE_BASE44_APP_ID=your_base44_app_id_here
VITE_BASE44_FUNCTIONS_VERSION=your_base44_functions_version_here
VITE_BASE44_APP_BASE_URL=https://app.base44.com

# ============================================
# Google Cloud (Optional - for Google Sheets integration)
# ============================================
# Create a Google Cloud project, enable Google Sheets API,
# and create an API key (restrict to server-side use only)
GOOGLE_SHEETS_API_KEY=your_google_cloud_api_key_here

# ============================================
# Mapbox (Optional - for custom map tiles)
# ============================================
MAPBOX_TOKEN=your_mapbox_token_here

# ============================================
# Development
# ============================================
NODE_ENV=development
